Options -Indexes
RewriteEngine On
RewriteBase /

# Security: block hidden files
RewriteRule ^\.           -  [F,L]

# Security: block direct access to CI folders
RewriteRule ^application/ -  [F,L]
RewriteRule ^system/      -  [F,L]
RewriteRule ^vendor/      -  [F,L]

# ===== CRITICAL: Pass through real files and directories =====
# ถ้าไฟล์หรือ folder มีจริง → ให้ web server serve โดยตรง
# ไม่ผ่าน CI3 (ครอบคลุม assets/, uploads/, ฯลฯ)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route ทุกอย่างที่เหลือผ่าน CI3
RewriteRule ^(.*)$ index.php?/$1 [L,QSA]
